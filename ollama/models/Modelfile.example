### Example Modelfile for importing a local GGUF model into Ollama
#
# 1) Download a .gguf file and put it into this folder (ollama/models/)
#    Example file name:
#      qwen2.5-0.5b-instruct-q4_k_m.gguf
#
# 2) Create a model inside the container:
#    docker compose exec ollama ollama create qwen2.5-local -f /models/Modelfile
#
# 3) Run:
#    docker compose exec ollama ollama run qwen2.5-local "Привет!"

FROM /models/your-model.gguf

PARAMETER temperature 0.2
PARAMETER top_p 0.9
PARAMETER num_ctx 2048

SYSTEM """Ты полезный ассистент. Отвечай кратко и по делу."""

