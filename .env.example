## Graylog / OpenSearch demo (local)
##
## Copy this file:
##   cp .env.example .env
##
## IMPORTANT:
## - GRAYLOG_PASSWORD_SECRET must be >= 16 chars
## - OPENSEARCH_INITIAL_ADMIN_PASSWORD MUST be "strong":
##   at least 8 chars and include: uppercase, lowercase, digit, special char
##

# Graylog image tag (override if needed, e.g. graylog/graylog:7.0.1)
GRAYLOG_IMAGE=graylog/graylog:7.0

# External URL used by your browser to reach Graylog
GRAYLOG_HTTP_EXTERNAL_URI=http://127.0.0.1:9000/

# CHANGE ME (>=16 chars). Used by Graylog to encrypt sensitive values.
GRAYLOG_PASSWORD_SECRET=ChangeMe_AtLeast16Chars_123

# Password hash for the built-in admin user (username: admin)
# Example for password "admin":
# 8c6976e5b5410415bde908bd4dee15dfb167a9c873fc4bb8a81f6f2ab448a918
GRAYLOG_ROOT_PASSWORD_SHA2=8c6976e5b5410415bde908bd4dee15dfb167a9c873fc4bb8a81f6f2ab448a918

# OpenSearch initial admin password.
# Must contain: uppercase + lowercase + digit + special char.
OPENSEARCH_INITIAL_ADMIN_PASSWORD=ChangeMe1!StrongEnough
